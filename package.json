{
  "name": "auggie-workbench",
  "displayName": "Auggie Workbench",
  "description": "Auggie-powered VS Code sidebar over Agent Client Protocol, with a focused coding-agent workflow.",
  "version": "0.2.2",
  "publisher": "local",
  "license": "MIT",
  "icon": "resources/icon.png",
  "bugs": {
    "url": "https://github.com/us1415/vscode-acp/issues"
  },
  "homepage": "https://github.com/us1415/vscode-acp/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/us1415/vscode-acp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "acp",
    "agent",
    "ai",
    "coding agent",
    "copilot"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "auggie-workbench",
          "title": "Auggie",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "auggie-workbench": [
        {
          "id": "auggie-sessions",
          "name": "Threads",
          "type": "tree"
        },
        {
          "id": "auggie-chat",
          "name": "Auggie",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "auggie-sessions",
        "contents": "No Auggie threads yet.\n[New Thread](command:auggie.newConversation)"
      },
      {
        "view": "auggie-chat",
        "contents": "Open Auggie and start working in this workspace.\n[Start Auggie](command:auggie.connectAuggie)"
      }
    ],
    "commands": [
      {
        "command": "auggie.connectAuggie",
        "title": "Auggie: Start"
      },
      {
        "command": "auggie.connectAgent",
        "title": "Auggie: Connect",
        "icon": "$(plug)"
      },
      {
        "command": "auggie.newConversation",
        "title": "Auggie: New Thread",
        "icon": "$(add)"
      },
      {
        "command": "auggie.sendPrompt",
        "title": "Auggie: Focus Prompt"
      },
      {
        "command": "auggie.cancelTurn",
        "title": "Auggie: Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "auggie.disconnectAgent",
        "title": "Auggie: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "auggie.openChat",
        "title": "Auggie: Open Chat"
      },
      {
        "command": "auggie.openLatestThread",
        "title": "Auggie: Open Latest Thread",
        "icon": "$(history)"
      },
      {
        "command": "auggie.addAgent",
        "title": "Auggie: Configure Launch Command",
        "icon": "$(add)"
      },
      {
        "command": "auggie.removeAgent",
        "title": "Auggie: Remove Launch Command"
      },
      {
        "command": "auggie.showLog",
        "title": "Auggie: Show Log"
      },
      {
        "command": "auggie.showTraffic",
        "title": "Auggie: Show Protocol Traffic"
      },
      {
        "command": "auggie.browseRegistry",
        "title": "Auggie: Browse ACP Registry"
      },
      {
        "command": "auggie.setMode",
        "title": "Auggie: Set Mode"
      },
      {
        "command": "auggie.setModel",
        "title": "Auggie: Set Model"
      },
      {
        "command": "auggie.attachFile",
        "title": "Auggie: Attach File",
        "icon": "$(attach)"
      },
      {
        "command": "auggie.refreshAgents",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "auggie.refreshSessions",
        "title": "Auggie: Refresh Threads"
      },
      {
        "command": "auggie.openSession",
        "title": "Auggie: Open Thread"
      },
      {
        "command": "auggie.loadMoreSessions",
        "title": "Auggie: Load More Threads"
      },
      {
        "command": "auggie.copySessionId",
        "title": "Copy Session ID"
      },
      {
        "command": "auggie.forgetSession",
        "title": "Forget Session"
      },
      {
        "command": "auggie.restartAgent",
        "title": "Auggie: Restart",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "auggie.openSession",
          "when": "false"
        },
        {
          "command": "auggie.loadMoreSessions",
          "when": "false"
        },
        {
          "command": "auggie.copySessionId",
          "when": "false"
        },
        {
          "command": "auggie.forgetSession",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "auggie.addAgent",
          "when": "false",
          "group": "navigation@1"
        },
        {
          "command": "auggie.refreshAgents",
          "when": "view == auggie-sessions",
          "group": "navigation@3"
        },
        {
          "command": "auggie.openLatestThread",
          "when": "view == auggie-sessions",
          "group": "navigation@2"
        },
        {
          "command": "auggie.browseRegistry",
          "when": "false"
        },
        {
          "command": "auggie.newConversation",
          "when": "view == auggie-chat",
          "group": "navigation@1"
        },
        {
          "command": "auggie.attachFile",
          "when": "view == auggie-chat",
          "group": "navigation@2"
        },
        {
          "command": "auggie.cancelTurn",
          "when": "view == auggie-chat && auggie.turnInProgress",
          "group": "navigation@3"
        },
        {
          "command": "auggie.disconnectAgent",
          "when": "view == auggie-chat",
          "group": "navigation@4"
        },
        {
          "command": "auggie.showLog",
          "when": "view == auggie-chat"
        },
        {
          "command": "auggie.showTraffic",
          "when": "view == auggie-chat"
        },
        {
          "command": "auggie.restartAgent",
          "when": "view == auggie-chat"
        }
      ],
      "view/item/context": [
        {
          "command": "auggie.connectAgent",
          "when": "view == auggie-sessions && viewItem == agent-disconnected",
          "group": "inline"
        },
        {
          "command": "auggie.disconnectAgent",
          "when": "view == auggie-sessions && viewItem == agent-connected",
          "group": "inline"
        },
        {
          "command": "auggie.removeAgent",
          "when": "false"
        },
        {
          "command": "auggie.restartAgent",
          "when": "view == auggie-sessions && viewItem == agent-connected"
        },
        {
          "command": "auggie.refreshSessions",
          "when": "view == auggie-sessions && viewItem =~ /^agent/",
          "group": "session@1"
        },
        {
          "command": "auggie.copySessionId",
          "when": "view == auggie-sessions && viewItem =~ /^session/",
          "group": "session@1"
        },
        {
          "command": "auggie.forgetSession",
          "when": "view == auggie-sessions && viewItem == session-local",
          "group": "session@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "auggie.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "auggie.cancelTurn",
        "key": "escape",
        "when": "auggie.turnInProgress"
      }
    ],
    "configuration": {
      "title": "Auggie Workbench",
      "properties": {
        "auggie.agents": {
          "type": "object",
          "description": "Auggie ACP launch configuration.",
          "default": {
            "Auggie CLI": {
              "command": "npx",
              "args": [
                "@augmentcode/auggie@latest",
                "--acp"
              ],
              "env": {
                "AUGMENT_DISABLE_AUTO_UPDATE": "1"
              }
            }
          }
        },
        "auggie.mcpServers": {
          "description": "MCP servers to attach to every ACP session. Accepts either an ACP-style array or Auggie's documented object keyed by server name.",
          "default": {},
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "array"
            }
          ]
        },
        "auggie.autoApprovePermissions": {
          "type": "string",
          "enum": [
            "ask",
            "allowAll"
          ],
          "default": "ask",
          "description": "Automatically approve agent permission requests. 'ask' always prompts, 'allowAll' approves everything."
        },
        "auggie.defaultWorkingDirectory": {
          "type": "string",
          "default": "",
          "description": "Default working directory for agent sessions. Leave empty to use the current workspace folder."
        },
        "auggie.logTraffic": {
          "type": "boolean",
          "default": true,
          "description": "Log all ACP protocol traffic to the output channel."
        },
        "auggie.autoConnectAuggie": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to Auggie when the sidebar activates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "lint": "eslint src --max-warnings 0",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.1",
    "@vscode/extension-telemetry": "^1.5.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}
